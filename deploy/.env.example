# NanoClaw deployment configuration for myia-ai-01
# Copy to .env and fill in values
# Two experiments: cluster-manager (internal) + web-explorer (external)

# ── z.ai API (flagship: GLM-5.1 or GLM-5-turbo) ─────────────────
# Each experiment has its own dedicated key
CLUSTER_Z_AI_API_KEY=your-cluster-key-here
CLUSTER_Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4

EXPLORER_Z_AI_API_KEY=your-explorer-key-here
EXPLORER_Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# ── Claude API (Anthropic direct — fallback if z.ai unavailable) ─
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Local LLMs (intensive use, no quota) ─────────────────────────
# Qwen3.5-35B-A3B (vLLM GPU 0+1, medium model)
LOCAL_MEDIUM_BASE_URL=https://api.medium.text-generation-webui.myia.io/v1
LOCAL_MEDIUM_API_KEY=your-medium-key-here

# OmniCoder3 (vLLM GPU 2, mini model)
LOCAL_MINI_BASE_URL=https://api.mini.text-generation-webui.myia.io/v1
LOCAL_MINI_API_KEY=your-mini-key-here

# ── RooSync (Exp. 1 only) ───────────────────────────────────────
ROOSYNC_SHARED_PATH=G:/.shared-state

# ── Communication channel (NOT WhatsApp) ─────────────────────────
# To be determined with the agent
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
