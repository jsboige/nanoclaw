# NanoClaw deployment configuration for myia-ai-01
# Copy to .env and fill in values
# Two experiments: cluster-manager (internal) + web-explorer (external)

# ── Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Uncomment to use z.ai local proxy instead of Anthropic direct
# ANTHROPIC_BASE_URL=https://z.ai/v1

# ── RooSync (Exp. 1 only) ───────────────────────────────────────
# Shared state path (Google Drive mount)
# Windows: G:/.shared-state or //server/share/.shared-state
# Docker: mounted as /workspace/extra/roosync (read-only)
ROOSYNC_SHARED_PATH=G:/.shared-state

# ── Optional: channel credentials (add as needed) ───────────────
# WHATSAPP_SESSION_PATH=./data/whatsapp
# TELEGRAM_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# DISCORD_BOT_TOKEN=...
